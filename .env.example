APP_ADMIN_INITIALIZER_ENABLED=true
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=change-me

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:3001

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/users_db
SPRING_DATASOURCE_USERNAME=postgres-user
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

POSTGRES_DB=users_db
POSTGRES_USER=postgres-user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
